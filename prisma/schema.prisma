generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subjects  Subject[]
}

model Subject {
  id         String   @id @default(uuid())
  name       String
  importance String
  priority   Float    @default(6.3)
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics     Topic[]
}

model Topic {
  id          String          @id @default(uuid())
  title       String
  relevance   String
  firstStudy  String
  performance Int             @default(0)
  lastRev     DateTime?
  nextRev     DateTime?
  subjectId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  easiness    Float           @default(2.5)
  interval    Int             @default(0)
  repetitions Int             @default(0)
  reviews     ReviewHistory[]
  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model ReviewHistory {
  id         String   @id @default(uuid())
  topicId    String
  grade      String
  reviewedAt DateTime @default(now())
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Quiz {
  id         String   @id @default(uuid())
  banca      String
  subject    String
  difficulty String
  questions  Json // Armazena o array completo de questões gerado pelo Gemini
  createdAt  DateTime @default(now())

  @@map("quizzes") // Define o nome da tabela no Supabase como minusculo
}
