generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subjects  Subject[]
}

model Subject {
  id         String  @id @default(uuid())
  name       String
  importance String
  color      String? @default("#3B82F6")
  priority   Float   @default(6.3)

  // --- CAMPOS PARA SRS ---
  lastReviewed DateTime @default(now()) // Quando foi a última vez que você estudou
  nextReview   DateTime @default(now()) // Quando o sistema deve te cobrar a revisão
  interval     Int      @default(1) // Quantos dias esperar para a próxima
  easiness     Float    @default(2.5) // Fator de facilidade (usado no cálculo do SM-2)

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics    Topic[]
  decks     Deck[]
}

model Topic {
  id        String  @id @default(uuid())
  title     String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // Relações com os módulos de estudo
  flashcards Flashcard[]
  questions  Quiz[]

  // SM-2 Metadados
  firstStudy      String          @default("Pendente")
  performance     Int             @default(0)
  easiness        Float           @default(2.5)
  relevance       String?         @default("5/10")
  interval        Int             @default(0)
  repetitions     Int             @default(0)
  lastRev         DateTime?
  nextRev         DateTime?       @default(now())
  reviewHistories ReviewHistory[]
}

model Deck {
  id        String   @id @default(cuid())
  title     String
  color     String // Para armazenar "bg-blue-500", etc.
  createdAt DateTime @default(now())

  // Relações
  subjectId  String?
  subject    Subject?    @relation(fields: [subjectId], references: [id])
  flashcards Flashcard[]
  userId     String // Importante para separar os decks de cada estudante
}

model Flashcard {
  id       String  @id @default(cuid())
  question String
  answer   String
  details  String?
  deckId   String
  deck     Deck    @relation(fields: [deckId], references: [id])

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])
}

model ReviewHistory {
  id         String   @id @default(uuid())
  topicId    String
  grade      String
  reviewedAt DateTime @default(now())
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Quiz {
  id         String   @id @default(uuid())
  banca      String
  subject    String
  difficulty String
  questions  Json // Armazena o array completo de questões gerado pelo Gemini
  createdAt  DateTime @default(now())
  topic      Topic?   @relation(fields: [topicId], references: [id])
  topicId    String?

  @@map("quizzes") // Define o nome da tabela no Supabase como minusculo
}
